<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTEÚDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1C1C1E">

        <!-- VISOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="24dp"
            android:background="#1C1C1E">

            <TextView
                android:id="@+id/tvExpressao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#8E8E93"
                android:textSize="22sp"
                android:gravity="end"
                android:maxLines="2"
                android:ellipsize="start" />

            <TextView
                android:id="@+id/tvResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold"
                android:gravity="end"
                android:maxLines="1"
                android:ellipsize="start" />

            <TextView
                android:id="@+id/tvAbrirCientifico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚗️ Científica"
                android:textColor="#FF9F0A"
                android:textSize="13sp"
                android:layout_gravity="start"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- GRADE DE BOTÕES -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"
            android:columnCount="4"
            android:rowCount="5"
            android:padding="8dp"
            android:background="#1C1C1E">

            <Button android:id="@+id/btnC"
                style="@style/BtnFuncao"
                android:text="C" />
            <Button android:id="@+id/btnPlusMinus"
                style="@style/BtnFuncao"
                android:text="+/-" />
            <Button android:id="@+id/btnPorcento"
                style="@style/BtnFuncao"
                android:text="%" />
            <Button android:id="@+id/btnDiv"
                style="@style/BtnOperador"
                android:text="÷" />

            <Button android:id="@+id/btn7"
                style="@style/BtnNumero"
                android:text="7" />
            <Button android:id="@+id/btn8"
                style="@style/BtnNumero"
                android:text="8" />
            <Button android:id="@+id/btn9"
                style="@style/BtnNumero"
                android:text="9" />
            <Button android:id="@+id/btnMult"
                style="@style/BtnOperador"
                android:text="×" />

            <Button android:id="@+id/btn4"
                style="@style/BtnNumero"
                android:text="4" />
            <Button android:id="@+id/btn5"
                style="@style/BtnNumero"
                android:text="5" />
            <Button android:id="@+id/btn6"
                style="@style/BtnNumero"
                android:text="6" />
            <Button android:id="@+id/btnSub"
                style="@style/BtnOperador"
                android:text="−" />

            <Button android:id="@+id/btn1"
                style="@style/BtnNumero"
                android:text="1" />
            <Button android:id="@+id/btn2"
                style="@style/BtnNumero"
                android:text="2" />
            <Button android:id="@+id/btn3"
                style="@style/BtnNumero"
                android:text="3" />
            <Button android:id="@+id/btnAdd"
                style="@style/BtnOperador"
                android:text="+" />

            <Button android:id="@+id/btn0"
                style="@style/BtnNumero"
                android:text="0"
                android:layout_columnSpan="2"
                android:layout_gravity="fill" />
            <Button android:id="@+id/btnPonto"
                style="@style/BtnNumero"
                android:text="." />
            <Button android:id="@+id/btnIgual"
                style="@style/BtnIgual"
                android:text="=" />

        </GridLayout>
    </LinearLayout>

    <!-- MENU LATERAL CIENTÍFICO -->
    <LinearLayout
        android:id="@+id/drawerCientifico"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#1C1C1E"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Funções Científicas"
            android:textColor="#FF9F0A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp" />

        <Button android:id="@+id/btnSen"
            style="@style/BtnCientifico"
            android:text="sen( x )" />
        <Button android:id="@+id/btnCos"
            style="@style/BtnCientifico"
            android:text="cos( x )" />
        <Button android:id="@+id/btnTan"
            style="@style/BtnCientifico"
            android:text="tan( x )" />
        <Button android:id="@+id/btnLog"
            style="@style/BtnCientifico"
            android:text="log( x )" />
        <Button android:id="@+id/btnLn"
            style="@style/BtnCientifico"
            android:text="ln( x )" />
        <Button android:id="@+id/btnPot"
            style="@style/BtnCientifico"
            android:text="x ^ y" />
        <Button android:id="@+id/btnRaiz"
            style="@style/BtnCientifico"
            android:text="√ x" />
        <Button android:id="@+id/btnPi"
            style="@style/BtnCientifico"
            android:text="π" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* Ângulos em graus"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>